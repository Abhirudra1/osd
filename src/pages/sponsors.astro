---
import Layout from "@/layouts/Layout.astro";
import "@/styles/2025/global.css";

const DUMMY_GOLD = [
  { label: "Platinum Sponsor" },
  { label: "Gold Sponsor A" },
  { label: "Gold Sponsor B" },
];
const DUMMY_SILVER = [
  { label: "Silver Sponsor A" },
  { label: "Silver Sponsor B" },
  { label: "Silver Sponsor C" },
];
const DUMMY_COMMUNITY = [
  "Event Partner", "Venue Partner", "Media Partner", "Tech Partner",
  "Community A", "Community B", "Community C", "Community D",
  "Community E", "Community F", "Community G", "Community H",
];
import PageHero from "@/components/PageHero.jsx";
---

<Layout title="Sponsors — Open Source Day 2026" activePath="/sponsors">
  <!-- Hero -->
  <PageHero client:load
    badge="APPLICATIONS OPEN"
    title="OSD 2026"
    titleGradient="SPONSORS"
    subtitle="Support India's biggest open source event and put your brand in front of 1000+ developers, engineers, and builders."
    primaryCta={{ text: "Become a Sponsor", href: "/cfs", external: true }}
    secondaryCta={{ text: "Community Partner", href: "/cfc", external: true }}
  />

  <section class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">Sponsorship <span class="gradient-text">Tiers</span></h2>
        <p class="text-gray-500">Choose the right tier to maximize your brand's impact</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Platinum -->
        <div class="border border-gray-200 rounded-2xl p-8 text-center hover:shadow-lg hover:-translate-y-1 transition-all duration-300 bg-white relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="bg-gray-800 text-white text-xs font-bold px-3 py-1 rounded-full">PLATINUM</span>
          </div>
          <div class="w-10 h-10 mx-auto mb-4 text-gray-500">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
            </svg>
          </div>
          <h3 class="font-black text-xl text-gray-900 mb-2">Platinum</h3>
          <p class="text-gray-500 text-sm mb-5">Top-tier visibility & maximum reach</p>
          <ul class="text-left space-y-2 text-sm text-gray-600 mb-6">
            {["Logo on all event materials", "Keynote speaking slot", "Premium booth location", "Social media features", "10 complimentary passes"].map(f => (
              <li class="flex items-center gap-2"><span class="text-green-500 font-bold">+</span> {f}</li>
            ))}
          </ul>
          <a href="/cfs" target="_blank" rel="noopener noreferrer" class="block w-full bg-gray-900 hover:bg-gray-800 text-white py-3 rounded-full font-bold transition-all text-sm">Contact Us</a>
        </div>
        <!-- Gold -->
        <div class="border-2 border-yellow-300 rounded-2xl p-8 text-center hover:shadow-lg hover:-translate-y-1 transition-all duration-300 bg-white relative scale-105">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="bg-yellow-400 text-gray-900 text-xs font-bold px-3 py-1 rounded-full">GOLD — POPULAR</span>
          </div>
          <div class="w-10 h-10 mx-auto mb-4 text-yellow-500">
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
            </svg>
          </div>
          <h3 class="font-black text-xl text-gray-900 mb-2">Gold</h3>
          <p class="text-gray-500 text-sm mb-5">Best value sponsor tier</p>
          <ul class="text-left space-y-2 text-sm text-gray-600 mb-6">
            {["Logo on all event materials", "Speaking slot (20 min)", "Exhibition booth", "Social media mentions", "6 complimentary passes"].map(f => (
              <li class="flex items-center gap-2"><span class="text-green-500 font-bold">+</span> {f}</li>
            ))}
          </ul>
          <a href="/cfs" target="_blank" rel="noopener noreferrer" class="block w-full bg-yellow-400 hover:bg-yellow-300 text-gray-900 py-3 rounded-full font-bold transition-all text-sm">Become a Sponsor</a>
        </div>
        <!-- Silver -->
        <div class="border border-gray-200 rounded-2xl p-8 text-center hover:shadow-lg hover:-translate-y-1 transition-all duration-300 bg-white relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="bg-gray-400 text-white text-xs font-bold px-3 py-1 rounded-full">SILVER</span>
          </div>
          <div class="w-10 h-10 mx-auto mb-4 text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 0 0 2.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 0 1 2.916.52 6.003 6.003 0 0 1-5.395 4.972m0 0a6.726 6.726 0 0 1-2.749 1.35m0 0a6.772 6.772 0 0 1-3.044 0" />
            </svg>
          </div>
          <h3 class="font-black text-xl text-gray-900 mb-2">Silver</h3>
          <p class="text-gray-500 text-sm mb-5">Essential sponsorship tier</p>
          <ul class="text-left space-y-2 text-sm text-gray-600 mb-6">
            {["Logo on website & backdrop", "Social media mentions", "Shared booth space", "3 complimentary passes"].map(f => (
              <li class="flex items-center gap-2"><span class="text-green-500 font-bold">+</span> {f}</li>
            ))}
          </ul>
          <a href="/cfs" target="_blank" rel="noopener noreferrer" class="block w-full bg-green-500 hover:bg-green-400 text-white py-3 rounded-full font-bold transition-all text-sm">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Current Partners (Dummy) -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">Our <span class="gradient-text">Partners</span></h2>
        <p class="text-gray-500">Organizations that make OSD 2026 possible</p>
      </div>

      <div class="mb-10">
        <div class="flex items-center gap-3 mb-5">
          <div class="h-px flex-1 bg-gray-200"></div>
          <span class="text-sm font-bold text-gray-400 uppercase tracking-widest">Gold Sponsors</span>
          <div class="h-px flex-1 bg-gray-200"></div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {DUMMY_GOLD.map((s) => (
            <div class="h-24 border-2 border-dashed border-gray-200 rounded-2xl flex items-center justify-center text-gray-400 text-sm font-medium bg-white hover:border-green-200 transition-colors">
              {s.label}
            </div>
          ))}
        </div>
      </div>

      <div class="mb-10">
        <div class="flex items-center gap-3 mb-5">
          <div class="h-px flex-1 bg-gray-200"></div>
          <span class="text-sm font-bold text-gray-400 uppercase tracking-widest">Silver Sponsors</span>
          <div class="h-px flex-1 bg-gray-200"></div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {DUMMY_SILVER.map((s) => (
            <div class="h-20 border-2 border-dashed border-gray-200 rounded-2xl flex items-center justify-center text-gray-400 text-sm font-medium bg-white hover:border-green-200 transition-colors">
              {s.label}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Community Partners -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto text-center">
      <div class="text-center mb-10">
        <h3 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">Community <span class="gradient-text">Partners</span></h3>
        <p class="text-gray-500">Amazing communities that support the open source movement</p>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {DUMMY_COMMUNITY.map((p) => (
          <div class="border-2 border-dashed border-gray-200 rounded-2xl px-6 py-3 text-gray-400 text-sm font-medium bg-gray-50 hover:border-green-200 transition-colors">
            {p}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Partnership Opportunities -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">Partnership <span class="gradient-text">Opportunities</span></h2>
        <p class="text-gray-500">Multiple ways to support and be part of OSD 2026</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { title: "Sponsor", desc: "Brand visibility, speaking opportunities, recruitment access, and more.", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />` },
          { title: "Community Partner", desc: "Co-promote with us, bring your community, amplify the open source movement.", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />` },
          { title: "Evangelist", desc: "Spread the word across your network, campus, or company.", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 0 1-1.44-4.282m3.102.069a18.03 18.03 0 0 1-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 0 1 8.835 2.535M10.34 6.66a23.847 23.847 0 0 1 8.835-2.535m0 0A23.74 23.74 0 0 1 18.795 3m.38 1.125a23.91 23.91 0 0 1 1.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 0 0 1.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 0 1 0 3.46" />` },
        ].map(({ title, desc, icon }) => (
          <div class="border border-gray-100 bg-white hover:border-green-200 hover:shadow-md p-7 rounded-2xl transition-all duration-300">
            <div class="w-10 h-10 mb-4 text-green-600">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" set:html={icon}></svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">{title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 px-4 bg-white text-center">
    <h3 class="text-2xl font-black text-gray-900 mb-3">Interested in <span class="gradient-text">sponsoring?</span></h3>
    <p class="text-gray-500 mb-2">Let's talk</p>
    <a href="mailto:opensourceweekend@gmail.com" class="text-green-600 hover:underline font-semibold">opensourceweekend@gmail.com</a>
  </section>
</Layout>
