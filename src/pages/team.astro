---
import Layout from "@/layouts/Layout.astro";
import "@/styles/2025/global.css";
import SquareUser from "@/assets/icons/square-user.svg";
import PageHero from "@/components/PageHero.jsx";
---

<Layout title="Team — Open Source Day 2026" activePath="/team">
  <!-- Hero -->
  <PageHero client:load
    badge="VOLUNTEER APPLICATIONS OPEN"
    title="MEET THE"
    titleGradient="OSD 2026 TEAM"
    subtitle="Volunteers are the heartbeat of Open Source Day. Join the 2026 crew and help create something legendary."
    primaryCta={{ text: "Apply to Volunteer", href: "/cfv", external: true }}
    secondaryCta={{ text: "View 2025 Team", href: "/2025/team" }}
  />

  <!-- Leadership -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">Leadership <span class="gradient-text">Team</span></h2>
        <p class="text-gray-500">The people steering OSD 2026</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-5">
        {[
          { role: "Event Director", desc: "Strategy & execution" },
          { role: "Program Manager", desc: "Schedule & content" },
          { role: "Design Lead", desc: "Brand & visual identity" },
          { role: "Tech Lead", desc: "Website & infra" },
        ].map((m) => (
          <div class="border border-gray-100 bg-white hover:border-green-200 hover:shadow-md p-6 rounded-2xl text-center transition-all duration-300">
            <div class="w-16 h-16 rounded-full mx-auto mb-4 bg-gradient-to-br from-green-50 to-green-100 flex items-center justify-center text-green-500 border border-green-100">
              <SquareUser class="w-7 h-7" />
            </div>
            <h4 class="font-bold text-gray-900">TBA</h4>
            <div class="text-sm text-green-600 font-medium mt-1">{m.role}</div>
            <div class="text-xs text-gray-400 mt-1">{m.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Volunteers -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">Core <span class="gradient-text">Volunteers</span></h2>
        <p class="text-gray-500">Our amazing volunteers that make OSD happen</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-5 gap-4">
        {Array.from({ length: 20 }).map((_, i) => (
          <div class="border border-gray-100 bg-white hover:border-green-200 hover:shadow-sm p-4 rounded-2xl text-center transition-all duration-300">
            <div class="w-14 h-14 rounded-full mx-auto mb-2 bg-gradient-to-br from-green-50 to-green-100 flex items-center justify-center text-green-500 border border-green-100">
              <SquareUser class="w-6 h-6" />
            </div>
            <div class="text-sm font-medium text-gray-700">Volunteer</div>
            <div class="text-xs text-gray-400">OSD 2026</div>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/cfv" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-bold text-white bg-gray-900 hover:bg-gray-800 px-8 py-3 rounded-full transition-all hover:scale-105">
          Join the Team
        </a>
      </div>
    </div>
  </section>

  <!-- Volunteer Roles -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">Volunteer <span class="gradient-text">Roles</span></h2>
        <p class="text-gray-500">Find the role that fits your skills and passion</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { title: "Event Coordination", desc: "Help plan sessions, manage timelines, and keep the event running smoothly.", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25Z" />` },
          { title: "Marketing & Outreach", desc: "Spread the word, manage social media, and grow the OSD 2026 community.", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 0 1-1.44-4.282m3.102.069a18.03 18.03 0 0 1-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 0 1 8.835 2.535M10.34 6.66a23.847 23.847 0 0 1 8.835-2.535m0 0A23.74 23.74 0 0 1 18.795 3m.38 1.125a23.91 23.91 0 0 1 1.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 0 0 1.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 0 1 0 3.46" />` },
          { title: "Technical Support", desc: "Support AV, live streaming, registration systems, and on-the-day tech.", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0H3" />` },
        ].map(({ title, desc, icon }) => (
          <div class="border border-gray-100 bg-white hover:border-green-200 hover:shadow-md p-7 rounded-2xl transition-all duration-300">
            <div class="w-10 h-10 mb-4 text-green-600">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" set:html={icon}></svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">{title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 px-4 bg-gray-50 text-center">
    <h3 class="text-2xl font-black text-gray-900 mb-3">Questions about <span class="gradient-text">volunteering?</span></h3>
    <p class="text-gray-500 mb-2">Reach us at</p>
    <a href="mailto:opensourceweekend@gmail.com" class="text-green-600 hover:underline font-semibold">opensourceweekend@gmail.com</a>
  </section>
</Layout>
